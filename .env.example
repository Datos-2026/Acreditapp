# Sin VPN, el Postgres remoto no responde: el login y toda la API fallan con error de base de datos.
# Opción local: en la raíz del repo ejecutá `docker compose up -d` y usá la URL de abajo.
# Opción remota: conectá VPN/red que permita alcanzar el host de tu DATABASE_URL.
#
# Local (docker-compose) o remoto. Ajustá sslmode si hay error TLS (disable / require).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gcba_acreditacion?schema=public&sslmode=disable"
API_PORT=4000
# Docker producción (Dockerfile): API_PORT=3000, sin Vite; el front se sirve desde Express.
WEB_PORT=5173
# En `npm run dev`, abrí solo el front (p. ej. http://localhost:5173): Vite reenvía /api al backend.
# Si el API no está en 127.0.0.1:4000: VITE_DEV_API_PROXY=http://127.0.0.1:PUERTO
#
# Build del front cuando API y web van en el mismo host (p. ej. imagen Docker):
#   VITE_API_URL=/api/v1 npm run build -w @gcba/web
# HTTPS detrás de proxy: COOKIE_SECURE=true
JWT_ACCESS_SECRET="dev_access_secret_change_me"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me"
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
# Varios orígenes separados por coma. Con localhost:5173 la API también acepta 127.0.0.1:5173.
CORS_ORIGIN="http://localhost:5173"
COOKIE_SECURE=false
