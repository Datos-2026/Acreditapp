{
  "name": "gcba-acreditacion-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm run dev -w @gcba/api\" \"npm run dev -w @gcba/web\"",
    "dev:api": "npm run dev -w @gcba/api",
    "dev:web": "npm run dev -w @gcba/web",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws",
    "test": "npm run test -ws",
    "db:migrate": "npm run db:migrate -w @gcba/api",
    "db:seed": "npm run db:seed -w @gcba/api",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.3.3"
  }
}
